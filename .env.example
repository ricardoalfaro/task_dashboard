# Configuración pública del cliente. La anon key puede exponerse en Vite porque
# las escrituras están protegidas por Supabase Auth y Row Level Security.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_BOARD_ID=00000000-0000-0000-0000-000000000000

# Solo para la rutina de servidor Supabase → Notion. Nunca usar prefijo VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_BOARD_ID=00000000-0000-0000-0000-000000000000
NOTION_TOKEN=your-server-only-notion-token
NOTION_DATA_SOURCE_ID=00000000-0000-0000-0000-000000000000
# EXPORT_SINCE=2026-07-01T00:00:00Z
# DRY_RUN=true
